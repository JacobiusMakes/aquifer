include LICENSE
include README.md
include CONTRIBUTING.md
include pyproject.toml

recursive-include docs *.md
recursive-include aquifer/dashboard/templates *.html
recursive-include aquifer/dashboard/static *

include aquifer/py.typed

# Exclude dev / CI artifacts
prune tests
prune .github
prune aquifer-claims
global-exclude *.pyc
global-exclude __pycache__
global-exclude .DS_Store
global-exclude ._*
