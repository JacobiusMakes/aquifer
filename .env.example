# Aquifer Strata Server Configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# === REQUIRED ===
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AQUIFER_MASTER_KEY=
AQUIFER_JWT_SECRET=

# === SERVER ===
AQUIFER_HOST=0.0.0.0
AQUIFER_PORT=8443
# AQUIFER_DEBUG=0
# AQUIFER_ALLOW_INSECURE_DEFAULTS=0

# === DATA ===
AQUIFER_DATA_DIR=/data/strata
# AQUIFER_DB_PATH=/data/strata/strata.db

# === PROCESSING ===
# AQUIFER_USE_NER=true
# AQUIFER_MAX_UPLOAD_BYTES=104857600

# === JWT ===
# AQUIFER_JWT_EXPIRY_HOURS=24

# === KEY ROTATION ===
# Set when rotating master key. Remove after all vaults re-encrypted.
# AQUIFER_PREVIOUS_MASTER_KEY=

# === EMAIL (for patient OTP delivery) ===
# AQUIFER_SMTP_HOST=smtp.gmail.com
# AQUIFER_SMTP_PORT=587
# AQUIFER_SMTP_USER=
# AQUIFER_SMTP_PASSWORD=
# AQUIFER_SMTP_FROM=noreply@aquifer.health
